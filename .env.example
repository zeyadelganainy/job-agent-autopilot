# Copy to .env and fill in. .env is gitignored (never committed).

# Primary LLM — Claude (Anthropic, paid BYOK): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Fallback LLM — Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Web monitoring console — login for the browser dashboard (a /login page; the demo
# button needs no credentials). HTTP Basic with these creds is also accepted.
WEB_USERNAME=admin
WEB_PASSWORD=change-me
# Optional: secret used to sign the login session cookie. Defaults to WEB_PASSWORD if
# unset; set a long random value to keep sessions valid across password changes.
SESSION_SECRET=

# Email digest (BYOK SMTP). Gmail: host smtp.gmail.com, port 587, an App Password as SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Public dashboard URL (used in the email's "Open the dashboard" link), e.g. https://you.duckdns.org
APP_URL=
