# Copy to .env and fill in. .env is gitignored.

# Primary LLM — Claude (Anthropic, paid BYOK): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Fallback LLM — Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram (talk to @BotFather to create a bot, @userinfobot for your chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web UI (v1.1) — login for the browser dashboard
WEB_USERNAME=admin
WEB_PASSWORD=change-me
